{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=IslamicPlatformDB;Trusted_Connection=True;MultipleActiveRe",
    "Redis": "localhost:6379"
  },

  "JWT": {
    "Key": "",
    "Issuer": "IslamicPlatform",
    "Audience": "IslamicPlatformUsers"
  },

  "Cloudinary": {
    "CloudName": "",
    "ApiKey": "",
    "ApiSecret": ""
  },

  "Gemini": {
    "ApiKey": "",
    "Model": ""
  },

  "AdminUser": {
    "Email": "",
    "Password": ""
  },

  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 60
      },
      {
        "Endpoint": "post:/api/auth/login",
        "Period": "5m",
        "Limit": 5
      },
      {
        "Endpoint": "post:/api/auth/register",
        "Period": "1h",
        "Limit": 3
      }
    ]
  }
}